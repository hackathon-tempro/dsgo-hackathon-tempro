# ============================================
# ENVIRONMENT CONFIGURATION
# ============================================

# Server & Environment
NODE_ENV=development
PORT=3000
API_VERSION=v1
API_BASE_URL=http://localhost:3000

# ============================================
# DATABASE CONFIGURATION
# ============================================

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=dsgo_dpp
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_SSL=false
DB_TIMEOUT=5000

# ============================================
# JWT & SECURITY
# ============================================

JWT_SECRET=test-secret-key-change-in-production-dsgo-dpp-2024
JWT_EXPIRY=24h
JWT_ALGORITHM=HS256
REFRESH_TOKEN_EXPIRY=7d

# Session & Cookies
SESSION_SECRET=test-session-secret-change-in-production
BCRYPT_ROUNDS=12

# CORS
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# ============================================
# CREDENCO INTEGRATION (Enabled with API Key)
# ============================================

FEATURE_CREDENCO_ENABLED=true
CREDENCO_API_BASE_URL=https://wallet.acc.credenco.com
CREDENCO_CLIENT_ID=dsgo-dpp-platform
CREDENCO_CLIENT_SECRET=117_E0KMoOcfCGklTW6kPxyE8XJAneR4K8gR
CREDENCO_TENANT_ID=default-tenant
CREDENCO_ISSUER_DID=did:credenco:dsgo-dpp-issuer
CREDENCO_WEBHOOK_SECRET=
CREDENCO_API_KEY=117_E0KMoOcfCGklTW6kPxyE8XJAneR4K8gR

# ============================================
# iSHARE INTEGRATION (Disabled for Testing)
# ============================================

FEATURE_ISHARE_ENABLED=false
ISHARE_SIMULATION_MODE=false
ISHARE_AUTHORITY_URL=https://trusted-list.ishare.eu
ISHARE_TOKEN_ENDPOINT=
ISHARE_DELEGATION_ENDPOINT=
ISHARE_CLIENT_ID=
ISHARE_CLIENT_SECRET=
ISHARE_PRIVATE_KEY_PATH=
ISHARE_CERTIFICATE_PATH=
ISHARE_EORI=

# ============================================
# FEATURES
# ============================================

FEATURE_BLOCKCHAIN_INTEGRATION=false
FEATURE_MULTI_SIGNATURE=false
FEATURE_DELEGATION_EVIDENCE=true
FEATURE_AUTOMATED_COMPLIANCE=false

# ============================================
# DPP CONFIGURATION
# ============================================

DPP_VERSION=1.0.0
DPP_APPEND_ONLY_ENFORCEMENT=true
DPP_MAX_BATCH_SIZE=1000
DPP_RETENTION_DAYS=2555

# ============================================
# AUDIT & LOGGING
# ============================================

AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=2555
AUDIT_LOG_LEVEL=INFO

LOG_LEVEL=debug
LOG_FORMAT=json
LOG_DIR=./logs
LOG_FILE_SIZE=10m
LOG_FILE_COUNT=30

# ============================================
# RATE LIMITING
# ============================================

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# STORAGE
# ============================================

STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=eu-west-1

# ============================================
# EMAIL (Optional)
# ============================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@dsgo-dpp.com

# ============================================
# CACHE
# ============================================

CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_TYPE=memory

# ============================================
# COMPLIANCE
# ============================================

COMPLIANCE_FRAMEWORK=EU_DPP_REGULATION_2024
COMPLIANCE_ENFORCEMENT=true

# ============================================
# EXTERNAL API
# ============================================

EXTERNAL_API_TIMEOUT=10000
EXTERNAL_API_RETRIES=3

# ============================================
# FRONTEND CONFIGURATION
# ============================================

VITE_API_URL=http://localhost:3000/api/v1
VITE_APP_NAME=DSGO DPP Platform
VITE_APP_VERSION=1.0.0
