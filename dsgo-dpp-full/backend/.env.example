# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1
LOG_LEVEL=debug

# Database Configuration
DATABASE_URL=postgresql://dsgo_user:dsgo_password@localhost:5432/dsgo_dpp
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dsgo_dpp
DB_USER=dsgo_user
DB_PASSWORD=dsgo_password
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_TIMEOUT=5000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d
JWT_ALGORITHM=HS256

# Credenco Business Wallet API
CREDENCO_API_BASE_URL=https://api.credenco.com/v2
CREDENCO_CLIENT_ID=your-credenco-client-id
CREDENCO_CLIENT_SECRET=your-credenco-client-secret
CREDENCO_ISSUER_DID=did:example:issuer
CREDENCO_CREDENTIAL_TEMPLATE_ID=your-template-id
CREDENCO_WEBHOOK_SECRET=your-webhook-secret

# iSHARE OAuth 2.0 Configuration
ISHARE_AUTHORITY_URL=https://trusted-list.ishare.eu
ISHARE_TOKEN_ENDPOINT=https://your-ishare-provider/token
ISHARE_DELEGATION_ENDPOINT=https://your-ishare-provider/delegation
ISHARE_CLIENT_ID=your-ishare-client-id
ISHARE_CLIENT_SECRET=your-ishare-client-secret
ISHARE_PRIVATE_KEY_PATH=./certs/ishare-private-key.pem
ISHARE_CERTIFICATE_PATH=./certs/ishare-certificate.pem
ISHARE_EORI=EU.EORI.XXXXXXXXXX

# DPP Configuration
DPP_VERSION=1.0.0
DPP_APPEND_ONLY_ENFORCEMENT=true
DPP_MAX_BATCH_SIZE=1000
DPP_RETENTION_DAYS=2555

# Audit Logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=2555
AUDIT_LOG_LEVEL=INFO

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-ID

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email Configuration (for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@example.com

# File Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_S3_BUCKET=dsgo-dpp-bucket
STORAGE_S3_REGION=eu-west-1

# API Keys for External Services
EXTERNAL_API_TIMEOUT=10000
EXTERNAL_API_RETRIES=3

# Feature Flags
FEATURE_BLOCKCHAIN_INTEGRATION=false
FEATURE_MULTI_SIGNATURE=true
FEATURE_DELEGATION_EVIDENCE=true
FEATURE_AUTOMATED_COMPLIANCE=false

# Logging Configuration
LOG_FORMAT=json
LOG_DIR=./logs
LOG_FILE_SIZE=10m
LOG_FILE_COUNT=30

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_TYPE=memory

# Organization Configuration
ORG_REGISTRATION_ENABLED=true
ORG_AUTO_APPROVAL=false
ORG_MAX_USERS_PER_ORG=1000

# Compliance Configuration
COMPLIANCE_FRAMEWORK=EU_DPP_REGULATION_2024
COMPLIANCE_ENFORCEMENT=true

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-change-in-production
ALLOWED_IP_WHITELIST=

# Webhook Configuration
WEBHOOK_TIMEOUT=5000
WEBHOOK_RETRIES=3
WEBHOOK_RETRY_DELAY=1000
