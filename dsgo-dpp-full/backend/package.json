{
  "name": "dsgo-dpp-backend",
  "version": "1.0.0",
  "description": "Digital Product Passport Backend - DSGO/DPP MVP with Credenco & iSHARE Integration",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "migrate": "node src/migrations/run.js",
    "seed": "node src/migrations/seed.js"
  },
  "keywords": [
    "DPP",
    "DSGO",
    "Digital Product Passport",
    "Credenco",
    "iSHARE",
    "Supply Chain",
    "Credentials",
    "Verifiable Credentials"
  ],
  "author": "DSGO Team",
  "license": "Apache-2.0",
  "dependencies": {
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-validator": "^7.0.0",
    "express-rate-limit": "^7.1.5",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "pg-migrate": "^1.0.2",
    "uuid": "^9.0.1",
    "jsonwebtoken": "^9.1.2",
    "jose": "^4.14.4",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "axios": "^1.6.2",
    "joi": "^17.11.0",
    "moment": "^2.29.4",
    "crypto": "^1.0.1",
    "node-cache": "^5.1.2",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
